:{"line":76,"column":19},"source":"index.js","original":{"line":76,"column":19},"name":"window"},{"generated":{"line":76,"column":25},"source":"index.js","original":{"line":76,"column":25}},{"generated":{"line":76,"column":26},"source":"index.js","original":{"line":76,"column":26},"name":"innerWidth"},{"generated":{"line":76,"column":36},"source":"index.js","original":{"line":76,"column":36}},{"generated":{"line":76,"column":38},"source":"index.js","original":{"line":76,"column":38},"name":"window"},{"generated":{"line":76,"column":44},"source":"index.js","original":{"line":76,"column":44}},{"generated":{"line":76,"column":45},"source":"index.js","original":{"line":76,"column":45},"name":"innerHeight"},{"generated":{"line":76,"column":56},"source":"index.js","original":{"line":76,"column":56}},{"generated":{"line":76,"column":57},"source":"index.js","original":{"line":76,"column":57}},{"generated":{"line":76,"column":58},"source":"index.js","original":{"line":76,"column":58}},{"generated":{"line":76,"column":59},"source":"index.js","original":{"line":76,"column":59}},{"generated":{"line":77,"column":0},"source":"index.js","original":{"line":77,"column":0}},{"generated":{"line":77,"column":1},"source":"index.js","original":{"line":77,"column":1}},{"generated":{"line":77,"column":2},"source":"index.js","original":{"line":77,"column":2}}],"sources":{"index.js":"import { PerspectiveCamera, Scene, WebGLRenderer, AxesHelper, BoxGeometry, MeshBasicMaterial, Mesh, TextureLoader } from \"three\";\r\nimport { OrbitControls } from \"three/examples/jsm/Addons.js\";\r\nimport pkq from './src/public/pkq.png'\r\nlet scene, camera, renderer, mesh, controls;\r\n\r\n// 初始化场景\r\nfunction initScene() {\r\n  scene = new Scene();\r\n}\r\n\r\n// 初始化相机\r\nfunction initCamera() {\r\n  camera = new PerspectiveCamera(45, window.innerWidth / window.innerHeight, 0.1, 1000);\r\n  camera.position.z = 10; // 往外拉一点\r\n}\r\n\r\n// 初始化渲染器\r\nfunction initRenderer() {\r\n  renderer = new WebGLRenderer({\r\n    antialias: true, // 抗锯齿\r\n  });\r\n  renderer.setSize(window.innerWidth, window.innerHeight);\r\n  document.body.appendChild(renderer.domElement);\r\n}\r\n\r\n// 初始化坐标\r\nfunction initAxesHelper() {\r\n  const axesHelper = new AxesHelper(3);\r\n  scene.add(axesHelper);\r\n}\r\n\r\n// 初始化轨道控制器\r\nfunction initOrbitControls() {\r\n  controls = new OrbitControls(camera, renderer.domElement);\r\n}\r\n\r\n// 引入物体\r\nfunction initMesh() {\r\n  const geometry = new BoxGeometry(); // 物体形状\r\n    const texture = new TextureLoader().load(pkq); // 物体纹理\r\n    const material = new MeshBasicMaterial({\r\n       color: 'yellow', // 物体颜色\r\n       map: texture, // 物体纹理\r\n      }); // 物体材质\r\n    mesh = new Mesh(geometry, material); // 物体网格\r\n    scene.add(mesh); // 把物体添加到场景中\r\n}\r\n\r\nfunction init() {\r\n  initScene();\r\n  initCamera();\r\n  initRenderer();\r\n  initAxesHelper();\r\n  initOrbitControls();\r\n  initMesh();\r\n}\r\n\r\ninit();\r\n\r\n// 动画\r\nfunction render() {\r\n  if (mesh.position.x >3) {\r\n\r\n  } else {\r\n    mesh.position.x += 0.01; // 物体往右移动\r\n  }\r\n  renderer.render(scene, camera); // 把三维场景渲染到页面上\r\n  requestAnimationFrame(render); // 循环调用render函数\r\n}\r\nrender();\r\n\r\n// 监听视口变化，自适应窗口\r\nwindow.addEventListener(\"resize\", () => {\r\n  camera.aspect = window.innerWidth / window.innerHeight; // 更新相机宽高比 \r\n  camera.updateProjectionMatrix(); // 更新相机投影矩阵\r\n  renderer.setSize(window.innerWidth, window.innerHeight); // 更新渲染器大小\r\n});"},"lineCount":null}},"error":null,"hash":"bc49068b6e5afef317b3374bf61b3857","cacheData":{"env":{}}}